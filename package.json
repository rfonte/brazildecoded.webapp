{
  "name": "brazildecoded.webapp",
  "version": "1.0.0",
  "private": true,
  "description": "BrazilDecoded static site (Eleventy).",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "server:dev": "node --loader dotenv/config backend-server.js",
    "server:watch": "nodemon --loader dotenv/config backend-server.js",
    "sd:report": "node tools/structured-data-report.js",
    "lint": "eslint \"src/assets/js/**/*.js\" && stylelint \"src/assets/css/**/*.css\" && htmlhint \"src/**/*.njk\"",
    "format": "prettier --write \"src/assets/js/**/*.js\" \"src/assets/css/**/*.css\" \"README.md\" \"docs/*.md\"",
    "format:check": "prettier --check \"src/assets/js/**/*.js\" \"src/assets/css/**/*.css\" \"README.md\" \"docs/*.md\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "sonar": "sonar-scanner",
    "sonar:summary": "node tools/sonar-summary.js",
    "prepush": "npm run test:unit && npm run test:unit:coverage && npm run sonar",
    "test:e2e": "playwright test",
    "docs": "jsdoc -c jsdoc.json",
    "postinstall": "playwright install --with-deps"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@playwright/test": "^1.48.2",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "html-minifier-terser": "^7.2.0",
    "htmlhint": "^1.1.4",
    "jsdoc": "^4.0.5",
    "jsdom": "^24.1.3",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.3",
    "sonar-scanner": "^3.1.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.17"
  }
}
