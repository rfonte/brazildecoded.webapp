# BrazilDecoded Backend Configuration

# Environment
NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client URL for CORS
CLIENT_URL=http://localhost:8080
SERVER_URL=http://localhost:3001

# Database (MVP: JSON, Production: MongoDB/PostgreSQL)
DATABASE_TYPE=json
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/brazildecoded

# Email Service (Opcional - para forgot password)
# RESEND_API_KEY=your-resend-key
# SENDGRID_API_KEY=your-sendgrid-key

# Logging
LOG_LEVEL=debug
