      <p class="section-note">Use a real email so the kit reaches you.</p>

      <form
        class="lead-form"
        id="starterKitForm"
        action="#"
        method="post"
        data-make-url="https://hook.us2.make.com/v7toev6h4hvpj1akkpsrhobamwdj9hkm"
