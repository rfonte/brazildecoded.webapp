<p class="section-note measure">Takes less than 5 minutes to read. Saves hours of avoidable mistakes.</p>

<section class="section" aria-labelledby="form-title">
  <div class="container">
    <div class="card">
      <h2 class="section-title" id="form-title">Get the Brazil travel starter kit</h2>
      <p class="section-note">Use a valid email to receive the material.</p>

      <form
        class="lead-form"
        id="starterKitForm"
        action="#"
        method="post"
        novalidate
      >
        <label for="leadName">Your name</label>
        <input
          type="text"
          id="leadName"
          name="name"
          autocomplete="name"
          placeholder="Your full name"
          required
          class="form-input"
        />

        <label for="leadEmail">Your email</label>
        <input
          type="email"
          id="leadEmail"
          name="email"
          autocomplete="email"
          placeholder="you@email.com"
          required
          aria-describedby="email-helper"
          class="form-input"
        />
        <p class="form-helper" id="email-helper">
          We will only send the starter kit and BrazilDecoded updates.
        </p>

        <label class="visually-hidden" for="company">Leave this field blank</label>
        <input
          type="text"
          id="company"
          name="company"
          tabindex="-1"
          autocomplete="off"
          style="display:none"
          aria-hidden="true"
        />

        <input type="hidden" name="source" value="free_starter_kit" />
        <input type="hidden" name="page" value="" />
        <input type="hidden" name="form_token" value="bd_starterkit_v1" />
        <input type="hidden" name="referrer" value="" />
        <input type="hidden" name="user_agent" value="" />
        <input type="hidden" name="utm_source" value="" />
        <input type="hidden" name="utm_medium" value="" />
        <input type="hidden" name="utm_campaign" value="" />
        <input type="hidden" name="utm_content" value="" />
        <input type="hidden" name="utm_term" value="" />
        <input type="hidden" name="turnstile_token" value="" />
        <input
          type="hidden"
          id="starterFormStartedAt"
          name="form_started_at"
        />

        <label>
          <input type="checkbox" id="consent" name="consent" required />
          I agree to receive the Starter Kit and occasional BrazilDecoded updates. No spam.
        </label>
        <p
          id="consentHelper"
          class="form-helper"
          role="status"
          aria-live="polite"
        >
          You must accept the consent to enable the button.
        </p>

        <button class="cta primary" id="leadSubmit" type="submit">
          Send me the Starter Kit
        </button>

        <p
          id="leadFeedback"
          class="form-feedback"
          role="status"
          data-status
        ></p>
      </form>
    </div>

    <div class="cta-row section">
      <a class="cta ghost" href="/">Back home</a>
    </div>
  </div>
</section>

