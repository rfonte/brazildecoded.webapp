---
title: "Free Brazil Travel Starter Kit | Checklist & Safety Tips"
description: "Free Brazil travel starter kit with safety tips, etiquette guidance, and a printable travel checklist. Get it by email in minutes."
layout: "layout.njk"
pageKey: "starter"
permalink: "/free-starter-kit/"
---

{# JSON-LD: Breadcrumbs for SEO #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ site.baseUrl }}/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Free Starter Kit",
      "item": "{{ site.baseUrl }}{{ page.url }}"
    }
  ]
}
</script>

<section class="hero hero--starter" aria-labelledby="starter-title">
  <div class="container hero-grid hero-grid--starter">

    {# LEFT: copy #}
    <div class="stack">
      <p class="eyebrow">Free download</p>
      <h1 id="starter-title">Free Brazil Travel Starter Kit</h1>
      <p class="lead measure">
        A practical PDF guide with safety tips, local etiquette, and a quick
        checklist to plan your trip to Brazil. Delivered by email.
      </p>
      <ul class="hero-highlights" aria-label="Kit highlights">
        <li>Quick planning checklist</li>
        <li>Safety and etiquette tips</li>
        <li>Ideal for first-time visitors</li>
      </ul>
      <p class="hero-proof">Downloaded by first-time travelers from over 30 countries.</p>
    </div>

    {# RIGHT: form card #}
    <div class="starter-form-card">

      {# Success state — revealed after submit, replaces form #}
      <div id="starterSuccess" class="starter-success-panel" hidden aria-live="assertive">
        <div class="starter-success-icon" aria-hidden="true">✓</div>
        <h2 class="starter-success-heading">Check your inbox!</h2>
        <p class="starter-success-body">
          We sent the secure download link to<br>
          <strong id="starterSuccessEmail">your email</strong>.
        </p>
        <p class="starter-success-detail">
          The link expires in 24 hours. Didn't receive it? Check spam or promotions.
        </p>
        <a class="cta ghost starter-success-cta" href="/the-guide/">
          See the complete guide →
        </a>
      </div>

      {# Form #}
      <h2 class="starter-form-title" id="form-title">Get your free Starter Kit</h2>
      <p class="starter-form-subtitle">Your download link will arrive by email in minutes.</p>

      <form
        class="lead-form"
        id="starterKitForm"
        action=""
        method="post"
        novalidate
        aria-labelledby="form-title"
        data-endpoint="{{ site.apiUrl }}/cadastro"
      >
        <label for="leadName">Your name</label>
        <input
          type="text"
          id="leadName"
          name="name"
          autocomplete="name"
          placeholder="Your full name"
          required
          class="form-input"
        />

        <label for="leadEmail">Your email</label>
        <input
          type="email"
          id="leadEmail"
          name="email"
          autocomplete="email"
          placeholder="you@email.com"
          required
          aria-describedby="email-helper"
          class="form-input"
        />
        <p class="form-helper" id="email-helper">
          We will only send the starter kit and BrazilDecoded updates.
        </p>

        <label class="visually-hidden" for="company">Leave this field blank</label>
        <input
          type="text"
          id="company"
          name="company"
          tabindex="-1"
          autocomplete="off"
          style="position:absolute;left:-10000px"
          aria-hidden="true"
        />

        <input type="hidden" name="source" value="free_starter_kit" />
        <input type="hidden" name="page" value="" />
        <input type="hidden" name="form_token" value="bd_starterkit_v1" />
        <input type="hidden" name="referrer" value="" />
        <input type="hidden" name="user_agent" value="" />
        <input type="hidden" name="utm_source" value="" />
        <input type="hidden" name="utm_medium" value="" />
        <input type="hidden" name="utm_campaign" value="" />
        <input type="hidden" name="utm_content" value="" />
        <input type="hidden" name="utm_term" value="" />
        <input type="hidden" name="turnstile_token" value="" />
        <input
          type="hidden"
          id="starterFormStartedAt"
          name="form_started_at"
        />

        <label class="consent-label">
          <input type="checkbox" id="consent" name="consent" required />
          <span>I agree to receive the Starter Kit and occasional BrazilDecoded updates. No spam.</span>
        </label>
        <p
          id="consentHelper"
          class="form-helper"
          role="status"
          aria-live="polite"
        >
          You must accept the consent to enable the button.
        </p>

        <!-- Turnstile widget -->
        <div class="cf-turnstile"
             data-sitekey="{{ site.turnstileSiteKey }}"
             data-theme="auto"
             data-callback="onTurnstileSuccess"
             data-expired-callback="onTurnstileExpired"></div>

        <button class="cta primary starter-submit-btn" id="leadSubmit" type="submit">
          Send me the Starter Kit
        </button>

        <p
          id="leadFeedback"
          class="form-feedback"
          role="status"
          aria-live="polite"
          data-status
        ></p>
      </form>

    </div>{# /starter-form-card #}
  </div>
</section>

<div class="container">
  <div class="cta-row section">
    <a class="cta ghost" href="/">← Back home</a>
  </div>
</div>

