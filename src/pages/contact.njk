<section class="section" aria-labelledby="message-title">
  <div class="container">
    <div class="card">
      <h2 class="section-title" id="message-title">Contact the Brazil travel guide team</h2>
      <p class="section-note">
        By submitting this form, you acknowledge our
        <a href="/privacy/">Privacy Policy</a>.
      </p>

      <form
        id="contactForm"
        action="#"
        method="post"
        data-make-url="https://hook.us2.make.com/v7toev6h4hvpj1akkpsrhobamwdj9hkm"
      >
        <label for="contactName">Your name</label>
        <input
          type="text"
          id="contactName"
          name="name"
          autocomplete="name"
          required
          maxlength="100"
          class="form-input"
        />

        <label for="contactEmail">Your email</label>
        <input
          type="email"
          id="contactEmail"
          name="email"
          autocomplete="email"
          required
          class="form-input"
        />

        <label for="contactMessage">Message</label>
        <textarea
          id="contactMessage"
          name="message"
          rows="4"
          required
          maxlength="1000"
          class="form-input"
        ></textarea>

        <label class="visually-hidden" for="hp_contact"
          >Leave this field blank</label
        >
        <input
          type="text"
          id="hp_contact"
          name="company"
          class="visually-hidden"
          tabindex="-1"
          autocomplete="new-password"
          aria-hidden="true"
        />
        <input
          type="hidden"
          id="contactFormStartedAt"
          name="form_started_at"
        />

        <label>
          <input
            type="checkbox"
            id="contactConsent"
            name="contactConsent"
            required
          />
          I agree to the processing of my personal data as described in the
          <a href="/privacy/">Privacy Policy</a>.
        </label>
        <p
          id="contactConsentHelper"
          class="form-helper"
          role="status"
          aria-live="polite"
        >
          You must accept the consent to enable the button.
        </p>

        <button class="cta primary" id="contactSubmit" type="submit">
          Send message
        </button>
        <p id="contactFeedback" class="form-feedback" role="status"></p>
      </form>
    </div>

    <div class="cta-row section">
      <a class="cta primary" href="/free-starter-kit/">Get the Free Starter Kit</a>
      <a class="cta secondary" href="/the-guide/">Explore the Full Guide</a>
      <a class="cta ghost" href="/">Back home</a>
    </div>
  </div>
</section>
