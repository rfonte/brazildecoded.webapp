title: "BrazilDecoded — Starter Kit de Viagem (Grátis)"
description: "Baixe o Starter Kit de Viagem do BrazilDecoded por e-mail — dicas de segurança, etiqueta e checklist." 
layout: "layout.njk"
pageKey: "starter"
permalink: "/pages/cadastro.html"
---
<section class="hero" aria-labelledby="starter-title">
  <div class="container hero-grid">
    <div class="stack">
      <p class="eyebrow">Download grátis</p>
      <h1 id="starter-title">Starter Kit de Viagem — Brasil</h1>
      <p class="lead measure">
        Um guia prático em PDF com dicas de segurança, etiqueta local e um
        checklist rápido para planejar sua viagem ao Brasil. Enviado por e-mail.
      </p>
      <ul class="hero-highlights" aria-label="Kit highlights">
        <li>Checklist rápido de planejamento</li>
        <li>Dicas de segurança e etiqueta</li>
        <li>Indicado para quem visita o país pela primeira vez</li>
      </ul>
    </div>

    <aside class="card" aria-label="Starter kit summary">
      <h2 class="card-title">What happens next</h2>
      <p class="card-subtitle">
        You will get the starter kit by email. This prototype stores
        submissions locally.
      </p>
      <p class="section-note">
        Swap to Tally or Mailchimp when you are ready for real delivery.
      </p>
    </aside>
  </div>
</section>

<section class="section" aria-labelledby="form-title">
  <div class="container">
    <div class="card">
      <h2 class="section-title" id="form-title">Quero receber o kit</h2>
      <p class="section-note">Use um e-mail válido para receber o material.</p>

      <form
        class="lead-form"
        id="starterKitForm"
        action="#"
        method="post"
        novalidate
        data-make-url="https://hook.us2.make.com/v7toev6h4hvpj1akkpsrhobamwdj9hkm"
      >
        <label for="leadName">Your name (optional)</label>
        <input
          type="text"
          id="leadName"
          name="name"
          autocomplete="name"
          placeholder="John"
        />

        <label for="leadEmail">Your email</label>
        <input
          type="email"
          id="leadEmail"
          name="email"
          autocomplete="email"
          placeholder="you@email.com"
          required
          aria-describedby="email-helper"
        />
        <p class="form-helper" id="email-helper">
          We will only send the starter kit and BrazilDecoded updates.
        </p>

        <label class="visually-hidden" for="hp_lead"
          >Leave this field blank</label
        >
        <input
          type="text"
          id="hp_lead"
          name="company_hp"
          class="visually-hidden"
          tabindex="-1"
          autocomplete="new-password"
          aria-hidden="true"
        />

        <label>
          <input type="checkbox" id="consent" name="consent" required />
          Concordo em receber comunicações e ofertas do BrazilDecoded.
        </label>
        <p
          id="consentHelper"
          class="form-helper"
          role="status"
          aria-live="polite"
        >
          You must accept the consent to enable the button.
        </p>

        <button class="cta primary" id="leadSubmit" type="submit">
          Enviar o Starter Kit
        </button>

        <p
          id="leadFeedback"
          class="form-feedback"
          role="status"
          data-status
        ></p>
      </form>
    </div>

    <div class="cta-row section">
      <a
        class="cta primary"
        href="https://pay.hotmart.com/L98856517I"
        target="_blank"
        rel="noopener noreferrer"
      >
        Buy on Hotmart
      </a>
      <a
        class="cta secondary"
        href="https://cafonte.gumroad.com/l/brazildecoded"
        target="_blank"
        rel="noopener noreferrer"
      >
        Buy on Gumroad
      </a>
      <a class="cta ghost" href="/index.html">Back home</a>
    </div>
  </div>
</section>

{# JSON-LD: Product (digital starter kit) to improve appearance in search results #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Starter Kit de Viagem — BrazilDecoded",
  "description": "Guia em PDF com dicas de segurança, etiqueta e checklist para viajar pelo Brasil.",
  "brand": {
    "@type": "Organization",
    "name": "BrazilDecoded",
    "url": "{{ site.baseUrl }}"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ site.baseUrl }}{{ page.url }}",
    "price": "0.00",
    "priceCurrency": "BRL",
    "availability": "https://schema.org/InStock",
    "category": "Digital"
  }
}
</script>
