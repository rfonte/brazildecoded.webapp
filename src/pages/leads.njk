<form id="starterKitForm" class="form">
  <!-- honeypot anti-spam -->
  <input type="text" name="company" tabindex="-1" autocomplete="off" style="display:none" />

  <input type="email" name="email" placeholder="Your email" required />
  <input type="text" name="name" placeholder="First name (optional)" />

  <button type="submit" class="cta">Get the free guide</button>
  <p class="section-note" data-status></p>
</form>
