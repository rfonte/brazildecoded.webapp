<section class="section" aria-labelledby="message-title">
  <div class="container">
    <div class="card">
      <h2 class="section-title" id="message-title">Send your message</h2>
      <p class="section-note">
        This form sends messages through a temporary Make webhook. For production,
        connect a verified email service.
      </p>
      <p class="section-note">
        By submitting this form, you acknowledge our
        <a href="/pages/privacy.html">Privacy Policy</a>.
      </p>

      <form
        id="contactForm"
        action="#"
        method="post"
        data-make-url="https://hook.us2.make.com/v7toev6h4hvpj1akkpsrhobamwdj9hkm"
      >
        <label for="contactName">Your name</label>
        <input type="text" id="contactName" name="name" autocomplete="name" required />

        <label for="contactEmail">Your email</label>
        <input type="email" id="contactEmail" name="email" autocomplete="email" required />

        <label for="contactMessage">Message</label>
        <textarea id="contactMessage" name="message" rows="4" required></textarea>

        <label class="visually-hidden" for="hp_contact"
          >Leave this field blank</label
        >
        <input
          type="text"
          id="hp_contact"
          name="company"
          class="visually-hidden"
          tabindex="-1"
          autocomplete="new-password"
          aria-hidden="true"
        />

        <label>
          <input
            type="checkbox"
            id="contactConsent"
            name="contactConsent"
            required
          />
          I agree to the processing of my personal data as described in the
          <a href="/pages/privacy.html">Privacy Policy</a>.
        </label>
        <p
          id="contactConsentHelper"
          class="form-helper"
          role="status"
          aria-live="polite"
        >
          You must accept the consent to enable the button.
        </p>

        <button class="cta primary" id="contactSubmit" type="submit">
          Send message
        </button>
        <p id="contactFeedback" class="form-feedback" role="status"></p>
      </form>
    </div>

