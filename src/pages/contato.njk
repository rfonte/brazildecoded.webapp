<section class="section" aria-labelledby="message-title">
  <div class="container">
    <div class="card">
      <h2 class="section-title" id="message-title">Send a message</h2>
      <p class="section-note">
        This form stores messages in localStorage for this prototype.
      </p>

      <form id="contactForm" action="#" method="post">
        <label for="contactName">Your name</label>
        <input
          type="text"
          id="contactName"
          name="name"
          autocomplete="name"
          required
        />

        <label for="contactEmail">Your email</label>
        <input
          type="email"
          id="contactEmail"
          name="email"
          autocomplete="email"
          required
        />

        <label for="contactMessage">Message</label>
        <textarea id="contactMessage" name="message" rows="4" required></textarea>

        <label class="visually-hidden" for="hp_contact"
          >Leave this field blank</label
        >
        <input
          type="text"
          id="hp_contact"
          name="company"
          class="visually-hidden"
          tabindex="-1"
          autocomplete="off"
        />

        <button class="cta primary" type="submit">Send message</button>
        <p id="contactFeedback" class="form-feedback" role="status"></p>
      </form>
    </div>

    <div class="cta-row section">
      <a
        class="cta primary"
        href="https://pay.hotmart.com/L98856517I"
