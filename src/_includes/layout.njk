<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ title }}</title>
    <meta
      name="description"
      content="{{ description | default(site.description) }}"
    />
    {% if noindex %}
    <meta name="robots" content="noindex, nofollow" />
    {% endif %}
    {% if ogTitle %}
    <meta property="og:title" content="{{ ogTitle }}" />
    {% endif %}
    {% if ogDescription %}
    <meta property="og:description" content="{{ ogDescription }}" />
    {% endif %}
    {% if ogImage %}
    <meta property="og:image" content="{{ ogImage }}" />
    {% endif %}

    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "{{ site.gtmId }}");
    </script>
    <!-- End Google Tag Manager -->

    <link
      rel="stylesheet"
      href="/assets/css/style.css?v={{ site.buildVersion }}"
    />
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id={{ site.gtmId }}"
        height="0"
        width="0"
        style="display: none; visibility: hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#maincontent">Skip to content</a>

    <header class="site-header" id="top">
      <div class="container">
        <a class="brand" href="/index.html">{{ site.brand }}</a>
        <nav class="main-nav" aria-label="Main menu">
          <ul>
            {% for item in site.nav %}
            <li>
              <a
                href="{{ item.href }}"
                class="{{ item.class | default('') }}"
                {% if pageKey == item.key %}aria-current="page"{% endif %}
                >{{ item.label }}</a
              >
            </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    </header>

    <main id="maincontent" role="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <p>
          &copy; <span id="year"></span> {{ site.brand }}. All rights reserved.
        </p>
        <div class="footer-links">
          {% for link in site.footerLinks %}
          <a href="{{ link.href }}" target="_blank" rel="noopener noreferrer"
            >{{ link.label }}</a
          >
          {% endfor %}
        </div>
      </div>
    </footer>

    <script src="/assets/js/lib/starter-kit.js?v={{ site.buildVersion }}"></script>
    <script src="/assets/js/script.js?v={{ site.buildVersion }}"></script>
  </body>
</html>
