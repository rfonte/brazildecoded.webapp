<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ title }}</title>
    <meta name="description" content="{{ description | default(site.description) }}" />
    <meta name="google-site-verification" content="GwKXjSPv8jfDW6ujzzrmT-BbY9cuDHVS0rD-N88WvcM" />
    <link rel="canonical" href="{{ site.baseUrl }}{{ page.url }}" />
    <meta name="robots" content="index, follow" />
    {% if noindex %}
    <meta name="robots" content="noindex, nofollow" />
    {% endif %}
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    {% if ogTitle %}
    <meta property="og:title" content="{{ ogTitle }}" />
    {% else %}
    <meta property="og:title" content="{{ title }}" />
    {% endif %}
    {% if ogDescription %}
    <meta property="og:description" content="{{ ogDescription }}" />
    {% else %}
    <meta property="og:description" content="{{ description | default(site.description) }}" />
    {% endif %}
    {% if ogImage %}
    <meta property="og:image" content="{{ ogImage }}" />
    {% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    {% if site.twitter %}
    <meta name="twitter:site" content="{{ site.twitter }}" />
    {% endif %}
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link
      rel="preload"
      as="style"
      href="/assets/css/style.css?v={{ site.buildVersion }}"
    />

    {# JSON-LD: WebSite and Organization to help Google understand the brand #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "url": "{{ site.baseUrl }}",
          "name": "{{ site.brand }}",
          "description": "{{ site.description }}",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "{{ site.baseUrl }}/?s={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "name": "{{ site.brand }}",
          "url": "{{ site.baseUrl }}"
          {% if site.logo %},"logo":"{{ site.baseUrl }}{{ site.logo }}"{% endif %}
        }
      ]
    }
    </script>

    <link
      rel="stylesheet"
      href="/assets/css/style.css?v={{ site.buildVersion }}"
    />
  </head>

  <body data-gtm-id="{{ site.gtmId }}">
    <a class="skip-link" href="#maincontent">Skip to content</a>

    <header class="site-header" id="top">
      <div class="container">
        <a class="brand" href="/index.html" aria-label="{{ site.brand }}">
          {% if site.logo %}
          <img
            src="{{ site.logo }}"
            alt="{{ site.brand }} logo"
            width="128"
            height="86"
            loading="lazy"
            decoding="async"
          />
          {% endif %}
          <span class="brand-text visually-hidden">{{ site.brand }}</span>
        </a>
        <nav class="main-nav" aria-label="Main menu">
          <ul>
            {% for item in site.nav %}
            <li>
              <a
                href="{{ item.href }}"
                class="{{ item.class | default('') }}"
                {% if pageKey == item.key %}aria-current="page"{% endif %}
                >{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    </header>

    <main id="maincontent" role="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <p>
          &copy; <span id="year"></span> {{ site.brand }}. All rights reserved.
        </p>
        <div class="footer-links">
          {% for link in site.footerLinks %}
          <a href="{{ link.href }}" target="_blank" rel="noopener noreferrer"
            >{{ link.label }}</a
          >
          {% endfor %}
        </div>
      </div>
    </footer>

    <div
      class="cookie-banner is-hidden"
      id="cookieBanner"
      role="dialog"
      aria-live="polite"
      aria-label="Cookie consent"
    >
      <div class="cookie-banner__content">
        <p>
          We use essential cookies to ensure proper site operation. With your
          consent, we use performance and marketing cookies to improve your
          experience.
        </p>
        <div class="cookie-banner__actions">
          <a class="cta ghost" href="/pages/cookies.html">View policy</a>
          <button
            class="cta ghost"
            id="cookieSettings"
            type="button"
            aria-expanded="false"
            aria-controls="cookieSettingsPanel"
          >
            Preferences
          </button>
          <button class="cta ghost" id="cookieReject" type="button">
            Reject
          </button>
          <button class="cta primary" id="cookieAccept" type="button">
            Accept
          </button>
        </div>
      </div>
      <div
        class="cookie-banner__settings"
        id="cookieSettingsPanel"
        aria-hidden="true"
      >
        <p class="cookie-banner__note">Essential cookies are always on.</p>
        <label class="cookie-option">
          <input type="checkbox" id="cookieAnalytics" />
          Performance and analytics
        </label>
        <label class="cookie-option">
          <input type="checkbox" id="cookieMarketing" />
          Marketing
        </label>
        <div class="cookie-banner__actions">
          <button class="cta primary" id="cookieSave" type="button">
            Save preferences
          </button>
        </div>
      </div>
    </div>

    <script src="/assets/js/lib/starter-kit.js?v={{ site.buildVersion }}"></script>
    <script src="/assets/js/script.js?v={{ site.buildVersion }}"></script>
  </body>
</html>


