<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ title }}</title>
    <meta name="description" content="{{ description | default(site.description) }}" />
    <meta name="google-site-verification" content="GwKXjSPv8jfDW6ujzzrmT-BbY9cuDHVS0rD-N88WvcM" />
    <meta name="p:domain_verify" content="699071a59134c23320fa27296e5d386b" />
    <link
      rel="canonical"
      href="{% if canonicalUrl %}{{ site.baseUrl }}{{ canonicalUrl }}{% elif page.url == '/' %}{{ site.baseUrl }}/{% else %}{{ site.baseUrl }}{{ page.url }}{% endif %}"
    />
    {% if metaRefresh %}
    <meta http-equiv="refresh" content="{{ metaRefresh }}" />
    {% endif %}
    {% if noindex %}
    <meta name="robots" content="noindex, nofollow" />
    {% else %}
    <meta name="robots" content="index, follow" />
    {% endif %}
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    {% if ogTitle %}
    <meta property="og:title" content="{{ ogTitle }}" />
    {% else %}
    <meta property="og:title" content="{{ title }}" />
    {% endif %}
    {% if ogDescription %}
    <meta property="og:description" content="{{ ogDescription }}" />
    {% else %}
    <meta property="og:description" content="{{ description | default(site.description) }}" />
    {% endif %}
    <meta property="og:url" content="{% if page.url == '/' %}{{ site.baseUrl }}/{% else %}{{ site.baseUrl }}{{ page.url }}{% endif %}" />
    <meta property="og:site_name" content="{{ site.brand }}" />
    {% if ogImage %}
    <meta property="og:image" content="{{ site.baseUrl }}{{ ogImage }}" />
    {% elif site.logo %}
    <meta property="og:image" content="{{ site.baseUrl }}{{ site.logo }}" />
    {% endif %}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{% if ogTitle %}{{ ogTitle }}{% else %}{{ title }}{% endif %}" />
    <meta name="twitter:description" content="{% if ogDescription %}{{ ogDescription }}{% else %}{{ description | default(site.description) }}{% endif %}" />
    {% if ogImage or site.logo %}
    <meta name="twitter:image" content="{% if ogImage %}{{ site.baseUrl }}{{ ogImage }}{% else %}{{ site.baseUrl }}{{ site.logo }}{% endif %}" />
    {% endif %}
    {% if site.twitter %}
    <meta name="twitter:site" content="{{ site.twitter }}" />
    {% endif %}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="1024x1024"
      href="/assets/images/favicon.png"
    />
    <link rel="apple-touch-icon" href="/assets/images/favicon.png" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link
      rel="preload"
      as="style"
      href="/assets/css/style.css?v={{ site.buildVersion }}"
    />

    {# JSON-LD: WebSite, Organization, and Product for rich snippets #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "url": "{{ site.baseUrl }}",
          "name": "{{ site.brand }}",
          "description": "{{ site.description }}",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "{{ site.baseUrl }}/?s={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "name": "{{ site.brand }}",
          "url": "{{ site.baseUrl }}"
          {% if site.logo %},"logo":"{{ site.baseUrl }}{{ site.logo }}","image":"{{ site.baseUrl }}{{ site.logo }}"{% endif %}
        }
        {% if pageKey == "home" %},
        {
          "@type": "Product",
          "name": "BrazilDecoded: Secrets to a Perfect Vacation",
          "description": "A practical travel guide created by a Brazilian to help you explore Brazil with more confidence, safety, and cultural insight.",
          "image": "{{ site.baseUrl }}/assets/cover.png",
          "brand": {
            "@type": "Brand",
            "name": "{{ site.brand }}"
          },
          "offers": {
            "@type": "Offer",
            "price": "14.00",
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "priceValidUntil": "2025-12-31",
            "url": "{{ site.baseUrl }}",
            "shippingDetails": {
              "@type": "OfferShippingDetails",
              "shippingDestination": {
                "@type": "DefinedRegion",
                "addressCountry": "BR"
              },
              "shippingRate": {
                "@type": "MonetaryAmount",
                "value": "0.00",
                "currency": "USD"
              },
              "deliveryTime": {
                "@type": "ShippingDeliveryTime",
                "handlingTime": {
                  "@type": "QuantitativeValue",
                  "minValue": 0,
                  "maxValue": 0,
                  "unitCode": "DAY"
                },
                "transitTime": {
                  "@type": "QuantitativeValue",
                  "minValue": 0,
                  "maxValue": 0,
                  "unitCode": "DAY"
                }
              }
            },
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
              "applicableCountry": "BR"
            },
            "seller": {
              "@type": "Organization",
              "name": "{{ site.brand }}"
            }
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5.0",
            "reviewCount": "1"
          },
          "review": {
            "@type": "Review",
            "author": {
              "@type": "Person",
              "name": "Rodrigo Cafonte"
            },
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "5",
              "bestRating": "5"
            },
            "reviewBody": "As a Brazilian travel enthusiast, I created this guide to share authentic insights that help international visitors experience Brazil safely and confidently."
          }
        }
        {% endif %}
      ]
    }
    </script>

    <link
      rel="stylesheet"
      href="/assets/css/style.css?v={{ site.buildVersion }}"
    />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>

  <body data-gtm-id="{{ site.gtmId }}">
    <a class="skip-link" href="#maincontent">Skip to content</a>

    <header class="site-header" id="top">
      <div class="container">
        <a class="brand" href="/" aria-label="{{ site.brand }}">
          {% if site.logo %}
          <img
            src="{{ site.logo }}"
            alt="{{ site.brand }} logo"
            width="128"
            height="86"
            loading="lazy"
            decoding="async"
          />
          {% endif %}
          <span class="brand-text visually-hidden">{{ site.brand }}</span>
        </a>
        <nav class="main-nav" aria-label="Main menu">
          <ul>
            {% for item in site.nav %}
            <li>
              <a
                href="{{ item.href }}"
                class="{{ item.class | default('') }}"
                {% if pageKey == item.key %}aria-current="page"{% endif %}
                >{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </nav>
      </div>
    </header>

    {% if pageKey != "home" %}
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        {% if pageKey == "starter" %}
        <li aria-current="page">Free Starter Kit</li>
        {% elif pageKey == "guide" %}
        <li aria-current="page">The Guide</li>
        {% elif pageKey == "author" %}
        <li aria-current="page">About</li>
        {% elif pageKey == "contact" %}
        <li aria-current="page">Contact</li>
        {% elif pageKey == "safe" %}
        <li aria-current="page">Is Brazil Safe for Tourists?</li>
        {% elif pageKey == "tips" %}
        <li aria-current="page">Brazil Travel Tips</li>
        {% elif pageKey == "etiquette" %}
        <li aria-current="page">Brazil Cultural Etiquette</li>
        {% elif pageKey == "guarantee" %}
        <li aria-current="page">Guarantee</li>
        {% elif pageKey == "privacy" %}
        <li aria-current="page">Privacy Policy</li>
        {% elif pageKey == "cookies" %}
        <li aria-current="page">Cookies</li>
        {% elif pageKey == "terms" %}
        <li aria-current="page">Terms of Use</li>
        {% endif %}
      </ol>
    </nav>
    {% endif %}

    <main id="maincontent" role="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <div class="footer-title">{{ site.brand }}</div>
          <p class="footer-tagline">Travel tips for Brazil • Made for foreigners</p>
        </div>

        <nav class="footer-col" aria-label="Explore">
          <div class="footer-heading">Explore</div>
          <ul class="footer-links">
            <li><a href="/free-starter-kit/">Free Starter Kit</a></li>
            <li><a href="/the-guide/">The Guide</a></li>
            <li><a href="/about-the-author/">About</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </nav>

        <nav class="footer-col" aria-label="Legal">
          <div class="footer-heading">Legal</div>
          <ul class="footer-links">
            <li><a href="/guarantee/">Guarantee</a></li>
            <li><a href="/privacy/">Privacy Policy</a></li>
            <li><a href="/cookies/">Cookies</a></li>
            <li><a href="/terms/">Terms of Use</a></li>
          </ul>
        </nav>
      </div>

      <div class="container footer-bottom">
        <span>&copy; <span id="year"></span> {{ site.brand }}. All rights reserved.</span>
      </div>
    </footer>

    <div
      class="cookie-banner is-hidden"
      id="cookieBanner"
      role="dialog"
      aria-live="polite"
      aria-label="Cookie consent"
    >
      <div class="cookie-banner-content">
        <p>
          We use essential cookies to ensure proper site operation. With your
          consent, we use performance and marketing cookies to improve your
          experience.
        </p>
        <div class="cookie-banner-actions">
          <a class="cta ghost" href="/cookies/">View policy</a>
          <button
            class="cta ghost"
            id="cookieSettings"
            type="button"
            aria-expanded="false"
            aria-controls="cookieSettingsPanel"
          >
            Preferences
          </button>
          <button class="cta ghost" id="cookieReject" type="button">
            Reject
          </button>
          <button class="cta primary" id="cookieAccept" type="button">
            Accept
          </button>
        </div>
      </div>
      <div
        class="cookie-banner-settings"
        id="cookieSettingsPanel"
        aria-hidden="true"
      >
        <p class="cookie-banner-note">Essential cookies are always on.</p>
        <label class="cookie-option">
          <input type="checkbox" id="cookieAnalytics" />
          Performance and analytics
        </label>
        <label class="cookie-option">
          <input type="checkbox" id="cookieMarketing" />
          Marketing
        </label>
        <div class="cookie-banner-actions">
          <button class="cta primary" id="cookieSave" type="button">
            Save preferences
          </button>
        </div>
      </div>
    </div>

    <script src="/assets/js/lib/starter-kit.js?v={{ site.buildVersion }}"></script>
    <script src="/assets/js/script.js?v={{ site.buildVersion }}"></script>
  </body>
</html>
