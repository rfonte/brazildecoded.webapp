#!/bin/sh
set -e

echo "Running lint, tests, coverage, and Sonar before push..."
npm run lint
if [ -z "$SONAR_TOKEN" ]; then
  echo "SONAR_TOKEN is not set. Skipping SonarCloud scan."
  npm run test:unit
  npm run test:unit:coverage
  npm run test:e2e
  exit 0
fi
npm run test:unit
npm run test:unit:coverage
npm run sonar
npm run sonar:summary
npm run test:e2e
